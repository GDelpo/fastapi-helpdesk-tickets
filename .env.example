# ============================================================================
# Tickets Service - Environment variables
# ============================================================================
# Copy to .env and fill in real values. This file is committed; .env is not.

# App
DEBUG=False
LOG_FORMAT=json
SERVICE_NAME=Helpdesk

# Branding (override to customize the portal + emails for your organization)
COMPANY_NAME=Helpdesk
COMPANY_LEGAL_TAGLINE=
PORTAL_NAVBAR_TITLE=Helpdesk
SUPPORT_EMAIL=support@example.com
COMPANY_WEBSITE=https://example.com
COMPANY_LOGO_URL=
COMPANY_FAVICON_URL=
DOCS_URL=

# PostgreSQL database
DB_HOST=tickets_postgres
DB_PORT=5432
DB_NAME=tickets
DB_USER=tickets_user
DB_PASSWORD=change-me

# Identity service (external auth microservice that issues JWTs)
# Server-to-server URL (Docker network)
IDENTITY_SERVICE_URL=http://identity_api:8080/api/v1
# Browser-reachable URL (shown by Swagger UI tokenUrl)
IDENTITY_EXTERNAL_URL=http://localhost/identity/api/v1

# Mailsender service (outbound email microservice)
MAILSENDER_URL=http://mailsender_api:8081/api/v1/emails

# Portal base URL used in outgoing notification emails
PORTAL_BASE_URL=http://localhost/tickets/portal

# Service account in identity (role=service) for server-to-server calls
TICKETS_SERVICE_USER=tickets-service
TICKETS_SERVICE_PASSWORD=change-me
