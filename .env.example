# ============================================================================
# Tickets Service — Variables de entorno
# ============================================================================
# Copiar a .env y completar con valores reales

# App
DEBUG=False
LOG_FORMAT=json
SERVICE_NAME=Mesa de Ayuda

# Branding
COMPANY_NAME=Noble Seguros
COMPANY_LEGAL_TAGLINE=Entidad autorizada por la Superintendencia de Seguros de la Nacion
PORTAL_NAVBAR_TITLE=Noble Seguros
SUPPORT_EMAIL=sistemas@nobleseguros.com
COMPANY_WEBSITE=https://www.nobleseguros.com
COMPANY_LOGO_URL=https://documentos.nobleseguros.com/externo/noble_logo_negro.png
COMPANY_FAVICON_URL=https://www.nobleseguros.com/wp-content/uploads/2022/09/cropped-favicon-1-32x32.png

# Base de datos PostgreSQL
DB_HOST=tickets_postgres
DB_PORT=5432
DB_NAME=tickets
DB_USER=tickets_user
DB_PASSWORD=your-postgres-password-change-me

# Identity Service
IDENTITY_SERVICE_URL=http://identidad_api:8080/api/v1
IDENTITY_EXTERNAL_URL=http://192.168.190.95/identidad/api/v1

# Mailsender Service
MAILSENDER_URL=http://mailsender_api:8081/api/v1/emails

# Portal — URL base para links en emails de notificación
PORTAL_BASE_URL=http://192.168.190.95/tickets/portal

# Cuenta de servicio en identidad (role=service) para llamadas server-to-server
TICKETS_SERVICE_USER=tickets-service
TICKETS_SERVICE_PASSWORD=your-service-account-password
